# Chat feature ("Ask Alfred") — copy to .env.local and fill in real values.
# .env.local is gitignored; set these same vars in Vercel Project Settings too.

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Upstash Redis (REST) for rate limiting — https://console.upstash.com/
# Create a Redis database, then copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
